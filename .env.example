# Drittanbieter-Kontaktformular (eine der beiden Optionen)
#
# Formspree:  https://formspree.io  → Endpoint-URL eintragen, KEIN Access-Key nötig
#   PUBLIC_FORM_ENDPOINT=https://formspree.io/f/xxxxxxx
#
# Web3Forms:  https://web3forms.com → Endpoint fix + Access-Key aus dem Dashboard
#   PUBLIC_FORM_ENDPOINT=https://api.web3forms.com/submit
#   PUBLIC_FORM_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Ohne Endpoint fällt das Formular automatisch auf einen mailto-Link zurück.
PUBLIC_FORM_ENDPOINT=
PUBLIC_FORM_ACCESS_KEY=
