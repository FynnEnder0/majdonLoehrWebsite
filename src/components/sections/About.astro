---
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import CurtainRule from '../ui/CurtainRule.astro';
import MotionReveal from '../ui/MotionReveal.tsx';
import { castingFacts, skillGroups } from '../../data/profile';
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Section id="about" class="bg-stage-dark" aria-labelledby="about-heading">
  <MotionReveal client:visible>
    <Eyebrow act="I" text={t.about.eyebrow} />
    <div id="about-heading">
      <SectionHeading text={t.about.heading} class="mt-5" />
    </div>
  </MotionReveal>

  <div class="mt-12 grid gap-14 lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-20">
    <!-- Narrative Bio -->
    <MotionReveal client:visible delay={0.1}>
      <div class="max-w-prose-col space-y-6">
        {
          t.about.body.map((para) => (
            <p class="font-body text-2xl leading-relaxed text-warm-ash">{para}</p>
          ))
        }
      </div>
    </MotionReveal>

    <!-- Steckbrief + Fähigkeiten -->
    <MotionReveal client:visible delay={0.2}>
      <aside class="space-y-10">
        <div class="flex items-stretch gap-4">
          <CurtainRule class="min-h-full" />
          <div class="w-full">
            <h3 class="font-mono text-sm font-bold uppercase tracking-[0.2em] text-dusk-label">
              {lang === 'de' ? 'Steckbrief' : 'Profile'}
            </h3>
            <dl class="mt-4 space-y-2.5">
              {
                castingFacts.map((f) => (
                  <div class="flex justify-between gap-4 border-b border-wing-shadow pb-2.5">
                    <dt class="font-mono text-sm uppercase tracking-[0.08em] text-dusk-label">
                      {f.label[lang]}
                    </dt>
                    <dd class="text-right text-lg font-medium text-warm-ash">{f.value[lang]}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </div>

        <div class="flex items-stretch gap-4">
          <CurtainRule class="min-h-full" />
          <div>
            <h3 class="font-mono text-sm font-bold uppercase tracking-[0.2em] text-dusk-label">
              {lang === 'de' ? 'Besondere Fähigkeiten' : 'Special Skills'}
            </h3>
            <div class="mt-4 space-y-5">
              {
                skillGroups.map((group) => (
                  <div>
                    <p class="font-body text-xl font-semibold text-parchment">{group.title[lang]}</p>
                    <ul class="mt-1 flex flex-wrap gap-x-3 gap-y-1">
                      {group.items.map((item, i) => (
                        <li class="font-body text-lg text-warm-ash">
                          {item[lang]}
                          {i < group.items.length - 1 && (
                            <span class="ml-3 text-footlight/60">·</span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </aside>
    </MotionReveal>
  </div>
</Section>
