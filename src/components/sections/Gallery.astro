---
import { getImage } from 'astro:assets';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import GalleryClient from './GalleryClient.tsx';
import { gallery } from '../../data/gallery';
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Build-Zeit-Optimierung: Thumb (Grid) + Full (Lightbox) je Bild.
const items = await Promise.all(
  gallery.map(async (g) => {
    const thumb = await getImage({ src: g.src, width: 800, format: 'webp', quality: 72 });
    const full = await getImage({ src: g.src, width: 1600, format: 'webp', quality: 80 });
    // Generierte (orientierungs-korrigierte) Maße für korrektes Seitenverhältnis / CLS
    const width = Number(thumb.attributes.width ?? g.src.width);
    const height = Number(thumb.attributes.height ?? g.src.height);
    return {
      thumb: thumb.src,
      full: full.src,
      width,
      height,
      alt: g.alt[lang],
      category: g.category,
    };
  }),
);
---

<Section id="gallery" class="bg-wing-shadow/30" aria-labelledby="gallery-heading">
  <Eyebrow text={t.gallery.eyebrow} />
  <div id="gallery-heading">
    <SectionHeading text={t.gallery.heading} class="mt-5" />
  </div>

  <GalleryClient
    client:visible
    items={items}
    labels={{
      all: t.gallery.filterAll,
      stage: t.gallery.filterStage,
      portrait: t.gallery.filterPortrait,
      close: t.gallery.close,
      prev: t.gallery.prev,
      next: t.gallery.next,
    }}
  />

  <!-- Demo-Reel Platzhalter -->
  <div class="mt-16">
    <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-dusk-label">
      {t.gallery.reelHeading}
    </h3>
    <div
      class="mt-4 flex aspect-video w-full items-center justify-center border border-dashed border-wing-shadow bg-stage-dark/60"
    >
      <p class="font-body text-lg italic text-warm-ash/60">
        {t.gallery.reelPlaceholder}
      </p>
    </div>
  </div>
</Section>
